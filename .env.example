PORT=7000
TZ=Europe/Rome
NODE_ENV=production

ADMIN_PASS=change-me-admin
TELEMETRY_PASS=change-me-telemetry
PUBLIC_TELEMETRY=false

DATABASE_URL=
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DB_SSL=false

TMDB_API_KEY=
INDEXER_URL=

LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=350
CLUSTER_WORKERS=1

PUBLIC_BASE_URL=
CC_PROXY_SECRET=

# Rust Shield: fast protected fetch/cache layer before Axios/ImpIt/FlareSolverr.
# Keeps FlareSolverr as fallback only; fail-open means Leviathan continues even if Rust is down.
RUST_SHIELD_ENABLED=true
RUST_SHIELD_URL=http://rust-shield:8787
RUST_SHIELD_FIRST=true
RUST_SHIELD_FAIL_OPEN=true
RUST_SHIELD_CACHE_ENABLED=true
RUST_SHIELD_TIMEOUT_MS=1800
RUST_SHIELD_NODE_TIMEOUT_MS=2300
RUST_SHIELD_CONNECT_TIMEOUT_MS=900
RUST_SHIELD_CLIENT_TIMEOUT_MS=2600
RUST_SHIELD_CACHE_MAX=2000
RUST_SHIELD_CACHE_TTL_MS=1200000
RUST_SHIELD_STALE_TTL_MS=3600000
RUST_SHIELD_MAX_BODY_BYTES=2500000
RUST_SHIELD_POOL_MAX_IDLE_PER_HOST=64
RUST_SHIELD_WARMUP_CONCURRENCY=4
RUST_SHIELD_ALLOW_PRIVATE=false
RUST_SHIELD_LOG=info

# UPROT auto-captcha solver (MammaMia-style state, generated automatically).
# Auto mode uses tesseract.js OCR + FlareSolverr fallback for the captcha page.
# Set UPROT_MAMMAMIA_MODE=true to use the manual /uprot browser flow instead.
#
# Known limitations of the auto flow:
#   - If your FlareSolverr container's egress IP is on uprot.net's Cloudflare
#     blocklist, every request returns 500 ("Cloudflare has blocked..."). The
#     code now caches that ban per-host for 15 minutes to fail fast.
#   - uprot.net occasionally serves a canvas-rendered captcha that Tesseract
#     cannot read (confidence:0). When that happens, OCR fails and the
#     orchestrator marks the host as failed for UPROT_FAILURE_TTL_MS.
#   - When both above happen, switch to UPROT_MAMMAMIA_MODE=true and open
#     /uprot in a browser once. State is saved for 45 minutes.
UPROT_MAMMAMIA_MODE=false
UPROT_AUTO_STATE_ENABLED=true
UPROT_FLARE_ENABLED=true
EUROSTREAMING_UPROT_FLARE_ENABLED=true
UPROT_AUTO_STATE_RETRY_BUDGET=1
UPROT_FAILURE_TTL_MS=600000
# Optional override; falls back to FLARESOLVERR_URL when empty.
UPROT_FLARESOLVERR_URL=
FLARESOLVERR_URL=
# State file persists across restarts; default config/uprot_state.json.
UPROT_STATE_FILE=
UPROT_DEBUG=true
