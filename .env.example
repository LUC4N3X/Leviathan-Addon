PORT=7000
TZ=Europe/Rome
NODE_ENV=production

ADMIN_PASS=change-me-admin
TELEMETRY_PASS=change-me-telemetry
PUBLIC_TELEMETRY=false

DATABASE_URL=
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DB_SSL=false

TMDB_API_KEY=
INDEXER_URL=

LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=350
CLUSTER_WORKERS=1

PUBLIC_BASE_URL=
CC_PROXY_SECRET=

# CinemaCity Resolution Memory — self-learning id->URL layer that lets repeat
# lookups skip the full sitemap scan + IMDb-verification page fetches. It learns
# from successful resolutions, remembers confident "not on CinemaCity" misses for
# a short window, and self-heals (decays + evicts URLs that stop serving). All
# additive and safe: on any miss/uncertainty it falls back to the normal flow.
# CC_MEMORY=1                       # master switch (default on)
# CC_MEMORY_PERSIST=1               # best-effort JSON persistence across restarts (default on)
# CC_MEMORY_PATH=                   # override persistence file (default providers/config/cc_resolution_memory.json)
# CC_MEMORY_POSITIVE_TTL_MS=1209600000   # remembered resolutions live 14 days
# CC_MEMORY_NEGATIVE_TTL_MS=21600000     # "not found" misses live 6 hours
# CC_MEMORY_HALF_LIFE_MS=604800000       # confidence half-life (7 days)
# CC_MEMORY_CONFIDENCE_FLOOR=0.45        # fuzzy matches below this re-resolve
# CC_MEMORY_MAX_FAILURES=2               # consecutive fetch failures before eviction
# CC_MEMORY_MAX_ENTRIES=5000             # LRU cap

# CinemaCity curl_cffi fallback — when the Cloudflare worker is down or blocked,
# CinemaCity falls back to a direct-to-origin fetch using the shared curl_cffi
# (browser TLS impersonation) infra, the same one other providers use. The worker
# stays primary and is always tried first; curl_cffi only runs on worker failure.
# Requires the Python curl_cffi package (installed in the Docker image); degrades
# to worker-only when absent. Honours the global CURL_CFFI_ENABLED kill switch.
# CC_CURL_CFFI_FALLBACK=1           # set to 0 to disable the CinemaCity fallback

# CinemaCity catalog proxy host — reverse-proxy (Cloudflare Worker) used to fetch
# the sitemap and content pages, bypassing the origin Cloudflare block. Host only,
# no protocol. Defaults to the bundled fallback host when unset. Deploy your own
# from cinemacity-worker/ and set it here to stop depending on third-party infra.
# CINEMACITY_WORKER_HOST=your-worker.workers.dev
# CINEMACITY_PROXY_SECRET=                  # match the worker PROXY_SECRET if the worker is locked

# Shared curl_cffi adaptive transport — remembers which browser impersonation
# profiles are reliable per host and reorders future attempts accordingly. This is
# conservative: it does not add extra retries by itself, and can be disabled with
# CURL_CFFI_PROFILE_STATE=false.
# CURL_CFFI_PROFILE_STATE=true
# CURL_CFFI_PROFILE_STATE_PATH=/tmp/curl_cffi_profile_state.json
# CURL_CFFI_PROFILE_STATE_TTL_SECONDS=604800
# CURL_CFFI_ADAPTIVE_HTTP_VERSION=true
# CURL_CFFI_HTTP_VERSION_ON_RETRY=1.1

# CB01 curl_cffi fast fallback — impit/forward remains primary for speed.
# curl_cffi is only tried after the normal route fails and only if the current
# request still has enough time budget left.
# CB01_CURL_CFFI_FALLBACK=1
# CB01_CURL_CFFI_IMPERSONATE=auto
# CB01_CURL_CFFI_SEARCH_TIMEOUT_MS=4200
# CB01_CURL_CFFI_PAGE_TIMEOUT_MS=5200
# CB01_CURL_CFFI_MIN_REMAINING_MS=2600
# CB01_CURL_CFFI_RETRIES=0
# CB01_CURL_CFFI_WARMUP_ORIGIN=0

FORWARD_PROXY=

# OnlineSerieTV provider (ported from MammaMia). Scrapes the OST WordPress site
# (SearchWP live search -> film/serietv page -> uprot/msf link) and resolves the
# uprot link to a MaxStream playback URL. Origin pages are fetched through the
# shared FORWARD_PROXY + impit Chrome impersonation, exactly like CB01; uprot is
# resolved server-side via MediaFlow/Kraken (KRAKEN_URL / config.mediaflow.url),
# with a local maxstream extractor as fallback. Enable it per-user from the
# configure page (filters.enableOnlineserietv) — no global kill switch needed.
OST_BASE_URL=https://onlineserietv.lol
# OST_BASE_URL_2=
# OST_BASE_URL_3=
# OST_BASE_URLS=                        # comma-separated extra mirrors
# OST_PROVIDER_TIMEOUT=14000            # axios client timeout (ms)
# OST_IMPIT_STRATEGY=forward-first      # forward-first | direct-first | forward-only | direct-only
# OST_IMPIT_FORWARD_ENABLED=1           # use FORWARD_PROXY for origin fetches
# OST_IMPIT_DIRECT_FALLBACK=1           # fall back to a direct fetch when forward fails
# OST_SEARCH_TIMEOUT_MS=12000
# OST_PAGE_TIMEOUT_MS=12000
# OST_MAX_DETAIL_PAGES=6                # detail pages probed per search before giving up
# OST_YEAR_TOLERANCE=1                  # accepted |pageYear - metaYear| before relaxing
# OST_IMPIT_BROWSER=chrome125           # impit impersonation profile
# OST_DEBUG=0                           # 1 = verbose provider logs, OST_TRACE=1 for trace

# Rust Shield service was removed - the Node fallback chain
# (impit/axios/CloudflareBypassForScraping) covers the same workload in this single-worker
# deployment. Any leftover RUST_SHIELD_* env vars in custom .env files are
# now ignored by the stubbed client at providers/utils/rust_shield_client.js.

# UPROT auto-captcha solver (MammaMia-style state, generated automatically).
# Auto mode uses tesseract.js OCR + CloudflareBypassForScraping fallback for the captcha page.
# Set UPROT_MAMMAMIA_MODE=true to use the manual /uprot browser flow instead.
#
# Known limitations of the auto flow:
#   - If your CloudflareBypass container/proxy egress IP is on uprot.net's
#     Cloudflare blocklist, the code caches that ban per-host for 15 minutes
#     to fail fast.
#   - uprot.net occasionally serves a canvas-rendered captcha that Tesseract
#     cannot read (confidence:0). When that happens, OCR fails and the
#     orchestrator marks the host as failed for UPROT_FAILURE_TTL_MS.
#   - When both above happen, switch to UPROT_MAMMAMIA_MODE=true and open
#     /uprot in a browser once. State is saved for 45 minutes.
UPROT_MAMMAMIA_MODE=false
UPROT_AUTO_STATE_ENABLED=true
UPROT_CLOUDFLARE_BYPASS_ENABLED=true
EUROSTREAMING_UPROT_CLOUDFLARE_BYPASS_ENABLED=true
UPROT_AUTO_STATE_RETRY_BUDGET=1
UPROT_FAILURE_TTL_MS=600000

# CloudflareBypassForScraping service, replacing the old browser solver.
# Inside docker-compose use http://cloudflare-bypass:8000.
# The host port is ${CLOUDFLARE_BYPASS_PORT:-8008}:8000 only for manual tests.
CLOUDFLARE_BYPASS_IMAGE=ghcr.io/sarperavci/cloudflarebypassforscraping:latest
CLOUDFLARE_BYPASS_URL=http://cloudflare-bypass:8000
CLOUDFLARE_BYPASS_URLS=http://cloudflare-bypass:8000
CF_BYPASS_URL=http://cloudflare-bypass:8000
CF_BYPASS_URLS=http://cloudflare-bypass:8000
UPROT_CLOUDFLARE_BYPASS_URL=http://cloudflare-bypass:8000
CLOUDFLARE_BYPASS_WORKERS=1
# ANTIBOT_EXTRA_CHALLENGE_MARKERS=

# Shared protection for every provider using CloudflareBypass/cached clearance.
# This keeps 300 users from creating 300 live scrapes against the same domain.
BYPASS_TRAFFIC_GUARD_ENABLED=true
BYPASS_REQUEST_COALESCING_ENABLED=true
BYPASS_SITE_MIN_INTERVAL_MS=250
BYPASS_SITE_MAX_CONCURRENCY=2
BYPASS_SITE_MAX_QUEUE=300
BYPASS_SOLVE_MIN_INTERVAL_MS=2500
BYPASS_SOLVE_MAX_CONCURRENCY=1
BYPASS_SOLVE_MAX_QUEUE=80
BYPASS_SERVICE_MIN_INTERVAL_MS=500
BYPASS_SERVICE_MAX_CONCURRENCY=2
BYPASS_SERVICE_MAX_QUEUE=120
BYPASS_COOKIE_RESPONSE_CACHE_TTL_MS=30000
BYPASS_COOKIE_RESPONSE_CACHE_STALE_MS=60000
BYPASS_MIRROR_CACHE_TTL_MS=30000
BYPASS_MIRROR_CACHE_STALE_MS=60000
BYPASS_RESPONSE_CACHE_MAX_ENTRIES=1500

# GuardoSerie CloudflareBypass ownership
# Default: only leviathan-worker runs the expensive background Camoufox/CloudflareBypass daemon.
# API reads the warmed session from Redis and uses fast axios requests.
GUARDOSERIE_BACKGROUND_OWNER_ROLE=worker
GUARDOSERIE_API_FLARE_ENABLED=false
GUARDOSERIE_WORKER_FLARE_ENABLED=true
GUARDOSERIE_API_CLEARANCE_FALLBACK=false
GUARDOSERIE_EXTRACTOR_CLOUDFLARE_BYPASS=false
GUARDOSERIE_EXTRACTOR_CLOUDFLARE_BYPASS_MIRROR_FALLBACK=false

CLOUDFLARE_BYPASS_PORT=8008
CLOUDFLARE_BYPASS_MEM_LIMIT=1400m
CLOUDFLARE_BYPASS_MEMSWAP_LIMIT=1800m
CLOUDFLARE_BYPASS_CPUS=1.0
# State file persists across restarts; default config/uprot_state.json.
UPROT_STATE_FILE=
UPROT_DEBUG=true

# ============================== #
# Leviathan Intelligence Config   #
# ============================== #
# Centralized config model reads these once and exposes normalized settings
# through core/config/app_settings.js.
MAX_CONFIG_LENGTH=16384
TORRENT_INTELLIGENCE_RANKING=true
TORRENT_INTELLIGENCE_WEIGHT=1
QUALITY_INTELLIGENCE_RANKING=true
RANKING_EXPLAIN=true

# PostgreSQL cache/history retention. -1 disables torrent TTL cleanup where supported.
DB_STARTUP_CLEANUP_INTERVAL_SEC=3600
POSTGRES_TORRENT_CACHE_TTL_SEC=2592000
POSTGRES_DEBRID_CACHE_TTL_SEC=86400
POSTGRES_METRICS_TTL_SEC=2592000
POSTGRES_HISTORY_TTL_SEC=2592000
POSTGRES_HISTORY_TTL_DAYS=30
RANK_HISTORY_ENABLED=true
RANK_HISTORY_LIMIT=40

# Saved Cloud aggressive account snapshots.
SAVED_CLOUD_AGGRESSIVE=true
SAVED_CLOUD_SCAN_LIMIT=180
SAVED_CLOUD_SNAPSHOT_ENABLED=true
SAVED_CLOUD_SNAPSHOT_TTL_SEC=21600
SAVED_CLOUD_SNAPSHOT_WARM_MAX=250
SAVED_CLOUD_LIVE_FALLBACK=true
SAVED_CLOUD_CACHE_TTL_MS=90000

# Share the debrid availability "already checked" marker across users for
# global-cache services (TorBox, Premiumize, OffCloud, StremThru), so a single
# check serves the whole instance instead of once per user. Real-Debrid stays
# per-user (account-bound availability). Set to false to revert to per-user.
DEBRID_GLOBAL_CACHE_CHECK_ENABLED=true

# RD strict-fast: DB positives are treated as hints unless the availability
# recheck is still fresh. Foreground live probes get a short deadline; background
# backfill keeps warming the DB/cache after the response.
RD_STRICT_FAST_ENABLED=true
RD_FOREGROUND_PROBE_DEADLINE_MS=3500

# TorBox max cache checking. TorBox supports about 100 hashes per checkcached
# call; higher windows are split into 100-hash chunks and served from DB/cache
# before live API calls.
TB_CACHE_CHUNK_SIZE=100
TB_CACHE_SYNC_LIMIT=100
TB_CACHE_MAX_CONCURRENCY=8
TB_CACHE_PROGRESSIVE_WINDOWS=100,200,300

# External source context modes inspired by Comet-style live/background routing.
# Supported values: live, background, both, false.
EXT_SOURCE_TORRENTIO=live
EXT_SOURCE_MEDIAFUSION=both
EXT_SOURCE_COMET=background
EXT_SOURCE_ZILEAN=background
EXT_SOURCE_STREMTHRU=false

# TRACKER_LIST_URLS=
# TRACKER_REFRESH_HOURS=6
# TRACKER_FETCH_TIMEOUT_MS=5000
# TRACKER_ACTIVE_MAX=80
# TRACKER_MAGNET_MAX=30
# ENGINES_MAGNET_MAX_TRACKERS=30

# Live UDP seeder scrape (BEP-15). Refreshes stale/missing seeder counts by
# querying UDP trackers directly before seed-health ranking. Only runs in P2P
# mode (no debrid key configured), is fully time-budgeted, and degrades to a
# no-op on any failure. Disabled by default.
# UDP_SCRAPE_ENABLED=false
# UDP_SCRAPE_MAX_ITEMS=60               # cap candidates scraped per request
# UDP_SCRAPE_MAX_TRACKERS=5             # cap distinct UDP trackers queried
# UDP_SCRAPE_REFRESH_AT_OR_BELOW=3      # only refresh items with <= N seeders (or unknown)
# UDP_SCRAPE_PACKET_TIMEOUT_MS=2500     # per-datagram timeout
# UDP_SCRAPE_TRACKER_BUDGET_MS=4000     # max time spent per tracker
# UDP_SCRAPE_TOTAL_BUDGET_MS=6000       # overall scrape time budget per request

# Debrid cache federation — shares confirmed "cached on RD/TB" info hashes
# between workers/instances through Redis (hash debrid_cache:{service}). On a
# confirmed hit a hash is published; on lookup, peers apply a soft positive
# (likely_cached) to skip redundant probes. Episode-precision and the foreground
# probe still run. Requires REDIS_ENABLED. Disabled by default.
# DEBRID_CACHE_FEDERATION_ENABLED=false
# DEBRID_CACHE_FEDERATION_TTL_SECONDS=604800   # how long a shared hit stays valid (7d)

# Kraken / MediaFlow-compatible runtime used by web providers to resolve hoster pages.
KRAKEN_URL=
KRAKEN_API_PASSWORD=

# Altadefinizione/VidxGo extraction. Leviathan finds the page/source while Kraken handles fragile hoster extraction.
ALTADEFINIZIONE_KRAKEN_FIRST=true
ALTADEFINIZIONE_KRAKEN_EXTRACTOR_PATH=/extractor/video.m3u8
ALTADEFINIZIONE_MAX_SOURCES=5
