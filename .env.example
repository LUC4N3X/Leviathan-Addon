# HTTP
PORT=7000
TZ=Europe/Rome
NODE_ENV=production

# Admin and telemetry
# ADMIN_PASS protects /admin/* routes.
# TELEMETRY_PASS protects /api/stats, /api/runtime, /api/providers,
# /api/cache-health, /metrics and RD scanner diagnostics.
ADMIN_PASS=change-me-admin
TELEMETRY_PASS=change-me-telemetry
PUBLIC_TELEMETRY=false

# Database
# docker-compose.yml provides this internal Postgres by default.
DATABASE_URL=
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DB_SSL=false

# Optional integrations
TMDB_API_KEY=
INDEXER_URL=

# Runtime tuning
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=350
CLUSTER_WORKERS=1
