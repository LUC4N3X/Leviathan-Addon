{
  "name": "leviathan",
  "version": "3.2.0",
  "description": "Leviathan Edition - phased search planner + shared stream cache + premium ranking",
  "main": "core/server/addon.js",
  "scripts": {
    "start": "node core/server/addon.js",
    "dev": "nodemon -r dotenv/config core/server/addon.js",
    "clean": "rm -rf node_modules && npm ci",
    "test": "node --test",
    "lint": "node scripts/lint.js",
    "format": "node scripts/format.js",
    "format:check": "node scripts/format-check.js",
    "check": "npm run lint && npm run format:check && npm test",
    "bench": "node scripts/benchmark.js",
    "worker": "node core/workers/worker.js"
  },
  "dependencies": {
    "@torbox/torbox-api": "^1.0.9",
    "axios": "^1.18.0",
    "bottleneck": "^2.19.5",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "he": "^1.2.0",
    "helmet": "^8.2.0",
    "impit": "^0.14.1",
    "node-cache": "^5.1.2",
    "p-limit": "^7.3.0",
    "parse-torrent-title": "^3.0.1",
    "pg": "^8.21.0",
    "set-cookie-parser": "^3.1.0",
    "tough-cookie": "^6.0.1",
    "winston": "^3.17.0",
    "get-tracks-data": "^0.8.2"
  },
  "optionalDependencies": {
    "tesseract.js": "^7.0.0"
  },
  "overrides": {
    "form-data": "^4.0.6",
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=20.19 <25",
    "npm": ">=10.8 <12"
  },
  "packageManager": "npm@10.9.2",
  "private": true
}
